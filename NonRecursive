#include <stdio.h>

int birthdayCakeCandles(int arr[], int n) {

    int max = arr[0];
    int count = 1;

    for (int i = 1; i < n; i++) {

        if (arr[i] > max) {
            max = arr[i];
            count = 1;
        }
        else if (arr[i] == max) {
            count++;
        }
    }

    return count;
}

int main() {

    int n;
    scanf("%d", &n);

    if (n <= 0) {
        printf("Invalid input\n");
        return 0;
    }

    int arr[n];

    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);

        if (arr[i] <= 0) {
            printf("Invalid input\n");
            return 0;
        }
    }

    printf("%d\n", birthdayCakeCandles(arr, n));

    return 0;
}