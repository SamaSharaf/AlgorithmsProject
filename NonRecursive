#include <stdio.h>

int birthdayCakeCandles(int arr[], int n) {

    if (n <= 0) return 0;

    int max = arr[0];
    int count = 1;

    for (int i = 1; i < n; i++) {
        if (arr[i] > max) {
            max = arr[i];
            count = 1;
        } else if (arr[i] == max) {
            count++;
        }
    }

    return count;
}

int main() {
    int n;
    scanf("%d", &n);

    if(n <= 0){
        printf("0 (No Candles Exist)\n");
        return 0;
    }
    int arr[n];
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    printf("%d\n", birthdayCakeCandles(arr, n));

    return 0;
}