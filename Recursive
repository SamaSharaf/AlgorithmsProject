#include <stdio.h>

typedef struct {
    int max;
    int count;
} Result;

Result findMaxCount(int arr[], int n) {

    if (n == 1) {
        Result r = {arr[0], 1};
        return r;
    }

    Result prev = findMaxCount(arr, n - 1);

    if (arr[n - 1] > prev.max) {
        Result r = {arr[n - 1], 1};
        return r;
    } else if (arr[n - 1] == prev.max) {
        prev.count++;
        return prev;
    } else {
        return prev;
    }
}

int main() {
    int n;
    scanf("%d", &n);

    int arr[n];
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    Result res = findMaxCount(arr, n);
    printf("%d\n", res.count);

    return 0;
}